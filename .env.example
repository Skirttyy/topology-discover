# Copiaza acest fisier in .env si completeaza valorile reale.
# NU comite fisierul .env in Git (e deja in .gitignore).

# --- PostgreSQL ---
DB_NAME=topology
DB_USER=topology_user
DB_PASSWORD=schimba-aceasta-parola

# --- Jasypt (criptare credentiale device-uri in DB) ---
# Genereaza o cheie puternica, ex: openssl rand -base64 32
JASYPT_ENCRYPTOR_PASSWORD=schimba-aceasta-cheie-de-criptare

# --- Frontend ---
# IP-ul/domeniul la care va fi accesibil backend-ul din browser-ul tau
# (NU "postgres" sau "backend" - acelea sunt nume interne Docker; aici
# trebuie IP-ul real al VM-ului din Proxmox, accesibil din browser)
VITE_API_BASE_URL=http://192.168.1.50:8080
